{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"lib": [
			"ESNext"
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"~/*": [ "./src/*" ]
		},
		"skipLibCheck": true,
		"stripInternal": true,
		"strict": true,
		"target": "ESNext",
		"types": [
			"node"
		]
	},
	"include": [
		"./src/**/*"
	]
}
